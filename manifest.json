{
  "manifest_version": 3,
  "name": "WebMarkdown - 网页转Markdown工具",
  "version": "1.0.0",
  "description": "智能网页内容转Markdown工具，支持预览和一键复制，让文档整理更高效",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "WebMarkdown转换器",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "web_accessible_resources": [
    {
      "resources": ["turndown.min.js"],
      "matches": ["<all_urls>"]
    }
  ]
} 